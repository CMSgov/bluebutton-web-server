# Shared ENV vars file for the "web" service containter.

# Top level Djano settings:
DJANGO_SETTINGS_MODULE=hhs_oauth_server.settings.dev
DATABASES_CUSTOM=postgres://postgres:toor@db:5432/bluebutton
OAUTHLIB_INSECURE_TRANSPORT=true
DJANGO_SECURE_SESSION=False
DJANGO_LOG_JSON_FORMAT_PRETTY=${DJANGO_LOG_JSON_FORMAT_PRETTY}
BB2_SERVER_STD2FILE=${BB2_SERVER_STD2FILE}

# AWS credentials
AWS_DEFAULT_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SESSION_TOKEN=${AWS_SESSION_TOKEN}

# BFD credentials/settings
DJANGO_USER_ID_SALT=${DJANGO_USER_ID_SALT}
DJANGO_USER_ID_ITERATIONS=${DJANGO_USER_ID_ITERATIONS}
FHIR_URL="https://prod-sbx.fhir.bfd.cmscloud.local"
DJANGO_FHIR_CERTSTORE=/code/docker-compose/certstore/
# CORS configuration for local docker-based development
# Allow all origins by default in local dev; override with environment if needed
CORS_ORIGIN_ALLOW_ALL=True
# Comma-separated list of allowed origins when CORS_ORIGIN_ALLOW_ALL is False
# Example: CORS_ALLOWED_ORIGINS=https://localhost:3000, https://sandbox.bluebutton.cms.gov
